# Telegram API — get these from https://my.telegram.org/apps
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=replace_with_your_api_hash

# Optional — Telemetr catalog for “Discover”
# TELEMETR_API_KEY=
# TELEMETR_API_BASE=https://api.telemetr.io

SESSION_NAME=stl_search
STL_HOST=0.0.0.0
STL_PORT=8787
STL_DOWNLOAD_DIR=/downloads

# Which machine this process is (badge in the UI)
# Windows PC:
# STL_INSTANCE=windows
# STL_HOSTNAME=Tommy-Alienware
# Synology container sets these via docker-compose.

# Synology gateway — preferred Windows upstream (PC LAN IP). Used by stl-gateway.
# STL_WINDOWS_UPSTREAM=http://192.168.0.88:8787

# Search speed / rate-limit tradeoff (lower concurrency = fewer FloodWaits)
# SEARCH_CONCURRENCY=2
# SEARCH_DELAY_SECONDS=0.35
# SEARCH_VARIANT_DELAY=0.2
# SEARCH_MAX_VARIANTS_PER_TERM=4

# Deep crawl (Telegram API — counts toward FloodWait)
# DEEP_CRAWL_MAX_ROOTS=120
# DEEP_CRAWL_MAX_INSPECT=250
# LINK_CRAWL_LIMIT=800

# Join/mute pacing (Telegram API)
# JOIN_DELAY_SECONDS=5.0
# JOIN_MAX_WAIT_SECONDS=300

# Downloads — how many separate files can download at once (default 4)
# STL_DOWNLOAD_JOB_CONCURRENCY=4
# Connections per file (shared across a global budget of ~12 — keep low)
# STL_DOWNLOAD_CONNECTIONS=4
# STL_DOWNLOAD_CONN_BUDGET=12

# Windows only: set to 1 to allow the PC to sleep while the app is running
# STL_ALLOW_SLEEP=0
